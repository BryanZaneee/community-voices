# Copy to .env (repo root). All keys optional — see README "demo modes".
# LLM generation (either or both):
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
# Embeddings (needed for ingest + hybrid/vector retrieval; without it the
# app falls back to BM25 keyword retrieval over the committed data):
VOYAGE_API_KEY=
# Reddit ingest (only needed to run the crawler / live week pull).
# Free "script app" from https://www.reddit.com/prefs/apps — Reddit blocks
# unauthenticated .json access on many networks:
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
