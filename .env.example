# Copy to .env (repo root). Both keys are free; see the key table in README.
# LLM generation (reports, comparisons, blind judging):
DEEPSEEK_API_KEY=
# Optional: unlocks Claude Opus 4.8 / Sonnet 5 in the sidebar model picker:
ANTHROPIC_API_KEY=
